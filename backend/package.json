{
  "name": "organizador-tarefas-jwt",
  "version": "1.0.0",
  "description": "API simples de organizador de tarefas com autenticação JWT para prática de testes unitários e regressão.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
